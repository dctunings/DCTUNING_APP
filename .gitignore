# v3.14: map-multipliers.json gets copied to public/ by copy-web-catalogs for web build.
# Real source lives in resources/map-multipliers.json (committed); public/ copy is build artifact.
src/renderer/public/map-multipliers.json
# v3.12.0: recipe library. ~215 MB total of per-variant tune deltas. Too big to commit.
# Only the manifest.json (~460KB) is committed — it indexes recipes by (partNumber, hash).
# Individual recipe files are built from C:/temp/extract_recipes.js and deployed via
# a separate pipeline (Supabase storage or CDN host) — they're pulled on demand by the
# app when a user's ORI hash matches a manifest entry.
resources/recipes/**
!resources/recipes/manifest.json
src/renderer/public/recipes/**
!src/renderer/public/recipes/manifest.json
